{
  "name": "number9systemd",
  "displayName": "Number9 System D",
  "version": "1.0.0",
  "description": "Custom Angular & Tailwind CSS Dashboard System",
  "author": "Number9 Development Team",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "node scripts/set-env.js && ng build && cp src/assets/_redirects dist/number9systemd/browser/_redirects",
    "build:ci": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "npx playwright test --ui",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*{.ts,.html,.css,.json}\" tsconfig.json angular.json .eslintrc.json",
    "deploy": "npm run build && npx wrangler pages deploy dist/number9systemd/browser --project-name=number9-admin --branch=main --commit-dirty=true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.0",
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.0",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/platform-browser-dynamic": "22.0.0",
    "@angular/router": "22.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "angular-svg-icon": "^22.0.0",
    "apexcharts": "^5.13.0",
    "ng-apexcharts": "^2.4.0",
    "ngx-sonner": "2.0.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/build": "22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@playwright/test": "1.50.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "angular-eslint": "^21.4.0",
    "autoprefixer": "10.4.7",
    "eslint": "8.57.1",
    "jasmine-core": "3.10.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.0.3",
    "karma-jasmine": "4.0.0",
    "karma-jasmine-html-reporter": "1.7.0",
    "postcss": "8.5.3",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3"
  }
}
